# =============================================================================
# ОБЩИЕ НАСТРОЙКИ (Common Settings)
# =============================================================================
DEBUG=False
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# =============================================================================
# БАЗЫ ДАННЫХ (Database Configuration)
# =============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Auth Service Database
DB_NAME_AUTH=shower_auth_db
DB_HOST_AUTH=postgres

# Feedback Service Database
DB_NAME_FEEDBACK=shower_feedback_db
DB_HOST_FEEDBACK=postgres

# Booking Service Database
DB_NAME_BOOKING=shower_booking_db
DB_HOST_BOOKING=postgres

# Comments Service Database
DB_NAME_COMMENTS=shower_comments_db
DB_HOST_COMMENTS=postgres

# =============================================================================
# JWT (Общий для всех сервисов)
# =============================================================================
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24

# =============================================================================
# CORS (Общие разрешённые_origin)
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:3000

# =============================================================================
# МЕЖСЕРВИСНОЕ ВЗАИМОДЕЙСТВИЕ (Inter-service Communication)
# =============================================================================
AUTH_SERVICE_URL=http://auth-service:8000
FEEDBACK_SERVICE_URL=http://feedback-service:8000
BOOKING_SERVICE_URL=http://booking-service:8000
COMMENTS_SERVICE_URL=http://comments-service:8000

# =============================================================================
# TELEGRAM (Для feedback-service)
# =============================================================================
TELEGRAM_BOT_TOKEN=AAGLcK8piwUhL0rAf16wr4xuhLciaPqmLqo
TELEGRAM_CHAT_ID=350638036

# =============================================================================
# EMAIL CONFIGURATION (Для feedback-service)
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@shower-booking.com

# =============================================================================
# ALLOWED HOSTS (по сервисам)
# =============================================================================
ALLOWED_HOSTS_AUTH=localhost,127.0.0.1,auth-service
ALLOWED_HOSTS_FEEDBACK=localhost,127.0.0.1,feedback-service
ALLOWED_HOSTS_BOOKING=localhost,127.0.0.1,booking-service
ALLOWED_HOSTS_COMMENTS=localhost,127.0.0.1,comments-service